            "item": [
                {
                    "name": "Place Order",
                    "request": {
                        "method": "POST",
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": { "mode": "raw", "raw": "{\n    \"dhanClientId\": \"{{client_id}}\",\n    \"correlationId\": \"stockpulse-001\",\n    \"transactionType\": \"BUY\",\n    \"exchangeSegment\": \"NSE_EQ\",\n    \"productType\": \"INTRADAY\",\n    \"orderType\": \"MARKET\",\n    \"validity\": \"DAY\",\n    \"securityId\": \"{{security_id_reliance}}\",\n    \"quantity\": 1,\n    \"disclosedQuantity\": \"\",\n    \"price\": \"\",\n    \"triggerPrice\": \"\",\n    \"afterMarketOrder\": false,\n    \"amoTime\": \"\",\n    \"boProfitValue\": \"\",\n    \"boStopLossValue\": \"\"\n}" },
                        "url": { "raw": "{{base_url}}/v2/orders", "host": ["{{base_url}}"], "path": ["v2", "orders"] }
                    },
                    "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {", "    pm.environment.set('order_id', pm.response.json().orderId);", "}"] } }]
                },
                {
                    "name": "Modify Order",
                    "request": {
                        "method": "PUT",
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": { "mode": "raw", "raw": "{\n    \"dhanClientId\": \"{{client_id}}\",\n    \"orderId\": \"{{order_id}}\",\n    \"orderType\": \"LIMIT\",\n    \"legName\": \"\",\n    \"quantity\": 1,\n    \"price\": 2800.00,\n    \"disclosedQuantity\": \"\",\n    \"triggerPrice\": \"\",\n    \"validity\": \"DAY\"\n}" },
                        "url": { "raw": "{{base_url}}/v2/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["v2", "orders", "{{order_id}}"] }
                    }
                },
                {
                    "name": "Cancel Order",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": { "raw": "{{base_url}}/v2/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["v2", "orders", "{{order_id}}"] }
                    }
                },
                {
                    "name": "Slice Order",
