{
    "info": {
        "name": "Dhan API v2 — StockPulse",
        "description": "Complete Dhan API v2 collection for StockPulse trading platform. 56 endpoints covering orders, market data, portfolio, and WebSocket feeds.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "apikey",
        "apikey": [
            { "key": "key", "value": "access-token", "type": "string" },
            { "key": "value", "value": "{{access_token}}", "type": "string" },
            { "key": "in", "value": "header", "type": "string" }
        ]
    },
    "variable": [],
    "item": [
        {
            "name": "01 — Auth & Config",
            "item": [
                {
                    "name": "Generate Token (TOTP)",
                    "request": {
                        "method": "POST",
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": { "mode": "raw", "raw": "{\n    \"dhanClientId\": \"{{client_id}}\",\n    \"pin\": \"123456\",\n    \"totp\": \"000000\"\n}" },
                        "url": { "raw": "{{auth_url}}/app/generateAccessToken", "host": ["{{auth_url}}"], "path": ["app", "generateAccessToken"] }
                    },
                    "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {", "    var json = pm.response.json();", "    pm.environment.set('access_token', json.accessToken);", "    pm.environment.set('client_id', json.dhanClientId);", "}"] } }]
                },
                {
                    "name": "Renew Token",
                    "request": {
                        "method": "GET",
                        "header": [{ "key": "access-token", "value": "{{access_token}}" }, { "key": "dhanClientId", "value": "{{client_id}}" }],
                        "url": { "raw": "{{base_url}}/v2/RenewToken", "host": ["{{base_url}}"], "path": ["v2", "RenewToken"] }
                    }
                },
                {
                    "name": "Get Profile",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": { "raw": "{{base_url}}/v2/profile", "host": ["{{base_url}}"], "path": ["v2", "profile"] }
                    }
                },
                {
                    "name": "Set Static IP",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": { "raw": "{{base_url}}/v2/ip/setIP", "host": ["{{base_url}}"], "path": ["v2", "ip", "setIP"] }
                    }
                },
                {
                    "name": "Get Current IP",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": { "raw": "{{base_url}}/v2/ip/getIP", "host": ["{{base_url}}"], "path": ["v2", "ip", "getIP"] }
                    }
                }
            ]
        },
        {
